10 REM PONG-BASIC - TWO-PLAYER PONG FOR COMMANDER X16
20 REM BASIC PORT OF PONG-ASM AND PONG-C
30 REM === SCREEN INIT ===
40 SCREEN 3:REM 40X30 TEXT MODE (320X240)
50 COLOR 1,6:CLS
60 POKE $9F25,0:POKE $9F2C,0:REM BLACK BORDER
70 REM === UPLOAD PADDLE SPRITE DATA (128 BYTES AT VRAM $10000) ===
80 FOR I=0 TO 127:VPOKE 1,I,$11:NEXT
90 REM === UPLOAD BALL SPRITE DATA (32 BYTES AT VRAM $10080) ===
100 FOR I=0 TO 31:VPOKE 1,$0080+I,$11:NEXT
110 REM === CONFIGURE SPRITES ===
120 SPRMEM 0,1,0,0:SPRITE 0,3,0,0,0,2,0:REM P1 PADDLE 8X32
130 SPRMEM 1,1,0,0:SPRITE 1,3,0,0,0,2,0:REM P2 PADDLE 8X32
140 SPRMEM 2,1,$0080,0:SPRITE 2,3,0,0,0,0,0:REM BALL 8X8
150 REM === INIT GAME STATE ===
160 BX=156:BY=116:BD=2:BE=2:XD=0:YD=0
170 PA=104:PB=104:S1=0:S2=0:GV=0:FC=0
180 GOSUB 1400:GOSUB 1500
190 MOVSPR 0,16,PA:MOVSPR 1,296,PB:MOVSPR 2,BX,BY
200 REM ========== GAME LOOP ==========
210 SLEEP
220 VPOKE 1,$F9FA,0:REM SILENCE BOUNCE SFX
230 IF GV>0 THEN 1600
240 FC=FC+1:IF FC>255 THEN FC=0
250 JV=JOY(0)
260 REM P1: Y BTN ($40)=A KEY=UP, B BTN ($80)=Z KEY=DOWN
270 IF (JV AND 64) THEN PA=PA-3:IF PA<8 THEN PA=8
280 IF (JV AND 128) THEN PA=PA+3:IF PA>200 THEN PA=200
290 REM P2: UP ($08), DOWN ($04)
300 IF (JV AND 8) THEN PB=PB-3:IF PB<8 THEN PB=8
310 IF (JV AND 4) THEN PB=PB+3:IF PB>200 THEN PB=200
320 REM === BALL MOVEMENT ===
330 IF XD=0 THEN BX=BX+BD:GOTO 350
340 BX=BX-BD:IF BX<0 THEN BX=0
350 IF YD=0 THEN BY=BY+BE:GOTO 370
360 BY=BY-BE:IF BY<0 THEN BY=0
370 REM === WALL COLLISION ===
380 IF BY<8 THEN BY=8:YD=0:GOSUB 1300
390 IF BY>232 THEN BY=232:YD=1:GOSUB 1300
400 REM === PADDLE COLLISION ===
410 GOSUB 900
420 REM === UPDATE SPRITES ===
430 MOVSPR 0,16,PA:MOVSPR 1,296,PB:MOVSPR 2,BX,BY
440 GOTO 210
900 REM === PADDLE COLLISION ===
910 IF XD=0 THEN 960
920 REM BALL MOVING LEFT - CHECK P1 PADDLE
930 IF BX>24 THEN RETURN
940 IF BX<16 THEN 1150
950 IF BY+8>PA AND BY<PA+32 THEN XD=0:BX=24:PY=PA:GOSUB 1000:GOSUB 1300:RETURN
957 RETURN
960 REM BALL MOVING RIGHT - CHECK P2 PADDLE
970 IF BX+8<296 THEN RETURN
980 IF BX+8>304 THEN 1100
990 IF BY+8>PB AND BY<PB+32 THEN XD=1:BX=288:PY=PB:GOSUB 1000:GOSUB 1300:RETURN
995 GOTO 1100
1000 REM === ANGLE ADJUST ===
1010 OF=ABS(BY+4-(PY+16))
1020 IF OF<5 THEN BE=1:BD=3:RETURN
1030 IF OF<10 THEN BE=2:BD=2:RETURN
1040 BE=3:BD=2:RETURN
1100 REM === P1 SCORES ===
1110 S1=S1+1:GOSUB 1400:GOSUB 1350
1120 IF S1>=9 THEN GV=1:RETURN
1130 GOSUB 1800:SLEEP 59:VPOKE 1,$F9FE,0:RETURN
1150 REM === P2 SCORES ===
1160 S2=S2+1:GOSUB 1400:GOSUB 1350
1170 IF S2>=9 THEN GV=2:RETURN
1180 GOSUB 1800:SLEEP 59:VPOKE 1,$F9FE,0:RETURN
1300 REM === BOUNCE SFX (PSG VOICE 14) ===
1310 VPOKE 1,$F9F8,$7C:VPOKE 1,$F9F9,$0A
1320 VPOKE 1,$F9FA,$F0:VPOKE 1,$F9FB,$20
1330 RETURN
1350 REM === SCORE SFX (PSG VOICE 15) ===
1360 VPOKE 1,$F9FC,$25:VPOKE 1,$F9FD,$03
1370 VPOKE 1,$F9FE,$F0:VPOKE 1,$F9FF,$80
1380 RETURN
1400 REM === DRAW SCORES ===
1410 A=45056+24:REM $B000+COL12*2
1420 VPOKE 1,A,$10:VPOKE 1,A+1,$61
1430 VPOKE 1,A+2,$31:VPOKE 1,A+3,$61
1440 VPOKE 1,A+4,$3A:VPOKE 1,A+5,$61
1450 VPOKE 1,A+6,$30+S1:VPOKE 1,A+7,$61
1460 VPOKE 1,A+8,$20:VPOKE 1,A+9,$61
1470 VPOKE 1,A+10,$20:VPOKE 1,A+11,$61
1480 VPOKE 1,A+12,$20:VPOKE 1,A+13,$61
1482 VPOKE 1,A+14,$20:VPOKE 1,A+15,$61
1484 VPOKE 1,A+16,$10:VPOKE 1,A+17,$61
1486 VPOKE 1,A+18,$32:VPOKE 1,A+19,$61
1488 VPOKE 1,A+20,$3A:VPOKE 1,A+21,$61
1490 VPOKE 1,A+22,$30+S2:VPOKE 1,A+23,$61
1495 RETURN
1500 REM === DRAW CENTER LINE ===
1510 FOR R=1 TO 29
1520 A=45056+R*256+40
1530 IF (R AND 1)=0 THEN VPOKE 1,A,$5E:VPOKE 1,A+1,$61:GOTO 1550
1540 VPOKE 1,A,$20:VPOKE 1,A+1,$61
1550 NEXT
1560 RETURN
1600 REM === GAME OVER ===
1610 IF GV=1 THEN M$="PLAYER 1 WINS!":GOTO 1630
1620 M$="PLAYER 2 WINS!"
1630 A=45056+13*256+26
1640 FOR I=1 TO LEN(M$):C=ASC(MID$(M$,I,1))
1650 IF C>=65 AND C<=90 THEN SC=C-64:GOTO 1670
1660 SC=C
1670 VPOKE 1,A+(I-1)*2,SC:VPOKE 1,A+(I-1)*2+1,$61:NEXT
1680 N$="PRESS ANY KEY TO PLAY"
1690 A=45056+15*256+20
1700 FOR I=1 TO LEN(N$):C=ASC(MID$(N$,I,1))
1710 IF C>=65 AND C<=90 THEN SC=C-64:GOTO 1730
1720 SC=C
1730 VPOKE 1,A+(I-1)*2,SC:VPOKE 1,A+(I-1)*2+1,$61:NEXT
1740 VPOKE 1,$F9FA,0:VPOKE 1,$F9FE,0
1750 GET K$:IF K$="" THEN 1750
1760 GOTO 30
1800 REM === RESET BALL ===
1810 BX=156:BY=116:BD=2:BE=2
1820 XD=FC AND 1:YD=INT((FC AND 2)/2)
1830 RETURN
