**/.DS_Store
**/*.un
# Ignore contents of .claude by default (use /* not / so negations work)
.claude/*

# Explicitly allowlist project-related settings
!.claude/CLAUDE.md
!.claude/.clauderules
!.claude/agents/
!.claude/commands/
!.claude/prompts/
!.claude/skills/
!.claude/mcp.json
!.claude/settings.json

# Upstream repos (cloned by scripts/clone-repos.sh)
upstream/*
!upstream/README.md

# Build artifacts
projects/*/build/
*.prg
*.i
*.o
*.obj
*.sym
*.d64
*.sdcard
*.img
